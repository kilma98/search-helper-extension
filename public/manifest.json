{
  "manifest_version": 3,
  "name": "Search Helper",
  "version": "0.1.0",
  "description": "Enhance search queries with smarter suggestions.",
  "permissions": ["tabs"],
  "action": {
    "default_popup": "index.html",
    "default_title": "Search Helper"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "search-helper@example.com"
    }
  }
}